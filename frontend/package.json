{
    "name":  "rebit-admin-core-frontend",
    "version":  "0.1.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "vue-tsc --noEmit \u0026\u0026 vite build",
                    "preview":  "vite preview",
                    "typecheck":  "vue-tsc --noEmit",
                    "typecheck:e2e":  "tsc --project tsconfig.e2e.json --noEmit",
                    "check":  "npm run lint \u0026\u0026 npm run typecheck \u0026\u0026 npm run typecheck:e2e",
                    "lint":  "eslint . --ignore-pattern .gitignore",
                    "lint:fix":  "npm run lint -- --fix",
                    "e2e:server":  "cross-env VITE_API_URL=/api VITE_API_MOCKS_ENABLED=true VITE_SMARTCAPTCHA_CLIENT_KEY= vite --host 127.0.0.1 --port 4173 --strictPort",
                    "test:e2e":  "cross-env TS_NODE_PROJECT=tsconfig.e2e.json cucumber-js --config cucumber.mjs",
                    "test:e2e:run":  "start-server-and-test e2e:server http://127.0.0.1:4173 test:e2e",
                    "test:e2e:headed":  "cross-env PLAYWRIGHT_HEADLESS=false start-server-and-test e2e:server http://127.0.0.1:4173 test:e2e",
                    "test:e2e:install":  "playwright install --with-deps chromium"
                },
    "dependencies":  {
                         "@mdi/font":  "^7.4.47",
                         "@typescript-eslint/parser":  "8.47.0",
                         "@unhead/vue":  "^2.1.12",
                         "@vue/eslint-config-prettier":  "10.2.0",
                         "axios":  "1.13.2",
                         "date-fns":  "4.1.0",
                         "pinia":  "3.0.4",
                         "vee-validate":  "4.15.1",
                         "vite-plugin-vuetify":  "2.1.2",
                         "vue":  "3.5.24",
                         "vue-i18n":  "11.1.12",
                         "vue-router":  "4.6.3",
                         "vue-tabler-icons":  "2.21.0",
                         "vue3-perfect-scrollbar":  "2.0.0",
                         "vuetify":  "3.10.11"
                     },
    "devDependencies":  {
                            "@cucumber/cucumber":  "12.2.0",
                            "@eslint/js":  "9.39.1",
                            "@mdi/js":  "^7.4.47",
                            "@playwright/test":  "1.52.0",
                            "@tsconfig/node24":  "^24.0.3",
                            "@types/node":  "24.10.1",
                            "@vitejs/plugin-vue":  "6.0.2",
                            "@vue/tsconfig":  "0.8.1",
                            "cross-env":  "10.1.0",
                            "eslint":  "9.39.1",
                            "eslint-plugin-prettier":  "5.5.5",
                            "eslint-plugin-vue":  "10.5.1",
                            "globals":  "16.5.0",
                            "prettier":  "3.6.2",
                            "sass":  "1.94.1",
                            "sass-loader":  "16.0.6",
                            "start-server-and-test":  "2.1.2",
                            "ts-node":  "10.9.2",
                            "typescript":  "5.9.3",
                            "typescript-eslint":  "8.47.0",
                            "vite":  "7.2.2",
                            "vite-plugin-vue-devtools":  "^7.7.2",
                            "vue-cli-plugin-vuetify":  "2.5.8",
                            "vue-eslint-parser":  "^10.2.0",
                            "vue-tsc":  "3.1.4"
                        },
    "description":  "Frontend stack for ReBit Admin Core."
}