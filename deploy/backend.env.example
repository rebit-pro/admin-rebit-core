# Шаблон /srv/admin-rebit-core/swarm/backend.env — публикуется как Swarm config
# admin_backend_env_<BUILD> и монтируется в контейнеры как /app/.env.
# СЕКРЕТОВ ЗДЕСЬ НЕТ: пароли/ключи — в /srv/admin-rebit-core/swarm/secrets/* (см. deploy/secrets/).
APP_NAME="ReBit Admin Core"
APP_ENV=prod
APP_DEBUG=0

DB_HOST=api-postgres
DB_PORT=5432
DB_DATABASE=rebit_admin
DB_USERNAME=rebit
# DB_PASSWORD — НЕ здесь: контейнер получает DB_PASSWORD_FILE=/run/secrets/admin_db_password.

# SMARTCAPTCHA_SERVER_KEY — НЕ здесь: SMARTCAPTCHA_SERVER_KEY_FILE=/run/secrets/admin_smartcaptcha_server_key.
